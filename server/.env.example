# Server
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/newssite

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=8h

# Admin login alerts (Gmail + app password)
# Generate at https://myaccount.google.com/apppasswords (requires 2-Step Verification)
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_FROM_NAME=The Daily Lens
ADMIN_ALERT_EMAIL=thedailylensespace@gmail.com
CONTACT_EMAIL=thedailylensespace@gmail.com
CONTACT_EMAIL=thedailylensespace@gmail.com
CONTACT_EMAIL=thedailylensespace@gmail.com

# Evergreen pipeline (DeepSeek V4 Flash when DEEPSEEK_API_KEY is set)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
EVERGREEN_MODEL=deepseek-v4-flash
EVERGREEN_TIMEOUT_MS=180000

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Groq — SEO article generation fallback (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Bluesminds — primary news AI via GPT 5.4 (OpenAI-compatible gateway)
BLUESMINDS_API_KEY=
BLUESMINDS_BASE_URL=https://api.bluesminds.com/v1
BLUESMINDS_MODEL=gpt-5.4
BLUESMINDS_MAX_TOKENS=3600
BLUESMINDS_TIMEOUT_MS=120000

# OpenRouter — primary AI (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_SITE_URL=https://thedailylens.space
OPENROUTER_APP_NAME=The Daily Lens
OPENROUTER_MAX_TOKENS=6000

# Clod.io — fallback AI after OpenRouter (https://clod.io)
CLOD_API_KEY=
CLOD_BASE_URL=https://api.clod.io/v1
CLOD_MODEL=Llama 3.1 8B
CLOD_MAX_TOKENS=4096
CLOD_TIMEOUT_MS=120000

# Monetization — served at /ads.txt for AdSense / programmatic verification
# e.g. ADS_TXT="google.com, pub-0000000000000000, DIRECT, f08c47fec0942fa0"
ADS_TXT=

# Google Custom Search — hero images when source has none (https://programmablesearchengine.google.com)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# News APIs
NEWSAPI_KEY=
GNEWS_KEY=

# SEO Intelligence — Google Search Console (optional).
# When all three are set (and the `googleapis` package is installed), the
# Search Console tab and the AI Planner light up with real clicks, impressions,
# CTR, average position, and striking-distance queries. The service account
# must be added as a user on the GSC property.
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=
GSC_SITE_URL=https://thedailylens.space/

# Evergreen guides flagged for refresh after this many days (default 180).
# EVERGREEN_REFRESH_DAYS=180

# Cricket live scores (optional — free key at https://cricketdata.org/signup.aspx)
CRICKETDATA_API_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google AdSense (client uses VITE_ vars)
VITE_ADSENSE_PUBLISHER_ID=ca-pub-...

# Admin seed
ADMIN_EMAIL=admin@dailylens.com
ADMIN_PASSWORD=DailyLens2026!

# Set true to skip AI/cron news fetching (use demo seed + manual articles)
DISABLE_AI_PIPELINE=true

# Auto-share gap between AI publishes (ms). Default 12s with Bluesminds, 45s otherwise.
# AUTO_SHARE_PUBLISH_GAP_MS=12000
