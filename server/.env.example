# Server
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/newssite

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Groq — SEO article generation fallback (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# OpenRouter — primary SEO article rewriting (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=The Daily Lens
OPENROUTER_MAX_TOKENS=6000

# Google Custom Search — hero images when source has none (https://programmablesearchengine.google.com)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# News APIs
NEWSAPI_KEY=
GNEWS_KEY=

# Cricket live scores (optional — free key at https://cricketdata.org/signup.aspx)
CRICKETDATA_API_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google AdSense (client uses VITE_ vars)
VITE_ADSENSE_PUBLISHER_ID=ca-pub-...

# Admin seed
ADMIN_EMAIL=admin@dailylens.com
ADMIN_PASSWORD=DailyLens2026!

# Set true to skip AI/cron news fetching (use demo seed + manual articles)
DISABLE_AI_PIPELINE=true
